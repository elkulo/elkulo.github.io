---
import Layout from '@/layouts/Layout.astro'
import AboutPage from '@/components/pages/AboutPage'
import * as aboutMd from '@/content/about/index.md'

const html = aboutMd.compiledContent()
const { title, description, date } = aboutMd.frontmatter
const base = import.meta.env.BASE_URL
const attachedSrc = `${base}content/about/profile.jpg`

const post = { html }
const postContent = { title, description, date, attachedSrc }
---

<Layout title={title} description={description}>
  <AboutPage client:only="react" post={post} postContent={postContent} />
</Layout>
