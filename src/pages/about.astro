---
import Layout from '@/layouts/Layout.astro'
import AboutTemplate from '@/templates/about/about.template'
import * as aboutMd from '@/content/about/index.md'

const html = await aboutMd.compiledContent()
const { title, description, date } = aboutMd.frontmatter
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/')
const attachedSrc = `${base}content/about/profile.jpg`

const post = { html }
const postContent = { title, description, date, attachedSrc }
---

<Layout title={title} description={description}>
  <AboutTemplate client:only="react" post={post} postContent={postContent} />
</Layout>
