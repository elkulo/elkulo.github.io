{
  "name": "el.kulo",
  "description": "el.kulo, Built with Astro and React.",
  "license": "UNLICENSED",
  "private": true,
  "version": "11.0.0",
  "homepage": "https://elkulo.github.io/",
  "keywords": [
    "astro"
  ],
  "main": "n/a",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elkulo/elkulo.github.io"
  },
  "bugs": {
    "url": "https://github.com/elkulo/elkulo.github.io/issues"
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "run-p serve:* astro:dev",
    "astro:dev": "astro dev",
    "serve:api": "json-server --watch __serve__/api/database.json --port 3000",
    "serve:storage": "http-server __serve__/storage -a localhost --port 50080",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,astro,json,md}\"",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/react": "^4.0.0",
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.6",
    "@mui/material": "^6.4.6",
    "astro": "^5.0.0",
    "md5": "^2.3.0",
    "normalize.css": "^8.0.1",
    "prismjs": "^1.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-masonry-component": "^6.3.0",
    "react-transition-group": "^4.4.5",
    "sass": "^1.85.1",
    "ua-parser-js": "^2.0.2"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "http-server": "^14.1.1",
    "json-server": "^0.17.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.2"
  }
}
